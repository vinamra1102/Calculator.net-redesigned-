      "min": 1,
      "unit": "mpg"
    },
    {
      "id": "pricePerGallon",
      "label": "Price per gallon",
      "type": "currency",
      "default": 3.5,
      "min": 0
    }
  ],
  "kernel": "fuel-cost.calc.ts"
}

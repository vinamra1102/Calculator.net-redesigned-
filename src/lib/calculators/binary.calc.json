{
  "id": "binary",
  "category": "math",
  "title": "Binary Calculator",
  "summary": "Convert between binary, decimal, hexadecimal, and octal.",
  "inputs": [
    {
      "id": "value",
      "label": "Value",
      "type": "text",
      "default": "255",

        {
          "label": "Binary",
          "value": "2"
        },
        {
          "label": "Hexadecimal",
          "value": "16"
        },
        {
          "label": "Octal",
          "value": "8"
        }
      ]
    }
  ],
  "kernel": "binary.calc.ts"
}
